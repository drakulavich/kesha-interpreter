# Copy to .env on the Linux host, then `docker compose up -d`.

# --- Required ---------------------------------------------------------------
NGC_API_KEY=nvapi-REPLACE_ME

# --- Optional overrides -----------------------------------------------------
# Pick a different model profile for each service. Run
#   docker exec riva-nmt env | grep NIM_TAGS_SELECTOR
# on a running container to see what's actually available in your image.
#NMT_SELECTOR=name=riva-translate-1_6b
#ASR_SELECTOR=name=parakeet-1-1b-rnnt-multilingual,mode=str,model_type=multi
#TTS_SELECTOR=name=fastpitch-hifigan-en-us
