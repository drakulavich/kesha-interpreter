# Riva NMT gRPC endpoint (the cascade entry point)
RIVA_ENDPOINT=10.119.62.29:50051

# TLS (set to 1 if endpoint requires SSL)
RIVA_TLS=0

# NGC API key (only needed if endpoint requires auth)
# RIVA_API_KEY=nvapi-xxx

# TTS voice (Magpie multilingual voices)
# Sofia, Aria, Diego, Isabela, Jason, Leo, Louise, Mia, Pascal, Ray
RIVA_VOICE=Magpie-Multilingual.EN-US.Sofia

# Mic device override (optional, sox device name)
# MIC_DEVICE=default
