{
  "name": "ar-en-simul",
  "version": "0.1.0",
  "description": "Simultaneous Arabic → English speech translator CLI, powered by NVIDIA Riva NIM",
  "type": "module",
  "module": "src/index.ts",
  "bin": {
    "ar-en-simul": "./src/index.ts"
  },
  "scripts": {
    "start": "bun run src/index.ts",
    "dev": "bun run --watch src/index.ts"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.12.2",
    "@grpc/proto-loader": "^0.7.13",
    "mic": "^2.1.2",
    "speaker": "^0.5.5",
    "commander": "^12.1.0",
    "chalk": "^5.3.0",
    "node-vad": "^1.1.4"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^22.7.0"
  }
}
